{
  "title": "Arduino Energy Monitor - INA219",
  "tags": ["arduino", "energia", "ina219"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Tensão (V)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "energia_tensao",
          "legendFormat": "Tensão - {{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Corrente (A)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "energia_corrente",
          "legendFormat": "Corrente - {{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Potência (W)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "energia_potencia",
          "legendFormat": "Potência - {{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Status do Sensor",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "energia_status",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "INVÁLIDO", "color": "red"}}},
            {"type": "value", "options": {"1": {"text": "OK", "color": "green"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Consumo Total (Wh)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(energia_potencia) * 5 / 3600",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watth",
          "decimals": 3
        }
      }
    },
    {
      "id": 6,
      "title": "Histórico de Consumo",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "energia_tensao",
          "legendFormat": "Tensão (V) - {{instance}}",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "energia_corrente",
          "legendFormat": "Corrente (A) - {{instance}}",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "energia_potencia",
          "legendFormat": "Potência (W) - {{instance}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 5,
            "showPoints": "never"
          }
        }
      }
    }
  ]
}
